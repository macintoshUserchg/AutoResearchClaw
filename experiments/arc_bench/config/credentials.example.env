# =============================================================================
# ARC-Bench credentials — example template
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Loaders: `python-dotenv` reads `.env.local` automatically when bench scripts
# are invoked from this directory; otherwise `set -a; source .env.local; set +a`
# before running.
#
# Three integrations are wired through these variables:
#   1. CLAUDE_CODE_OAUTH_TOKEN — used by ColliderAgentSandbox / BiologyAgentSandbox
#      to invoke the `claude` CLI from inside the experiment workspace.
#   2. OPENAI_BASE_URL + OPENAI_API_KEY — primary LLM backend for the 23-stage
#      ResearchClaw pipeline (codex / gpt-4o / gpt-5 etc. via the proxied API).
#   3. (optional) MAGNUS_TOKEN / MAGNUS_ADDRESS — only needed if running
#      Magnus-cloud Madgraph / FBA jobs from inside the agent skills.
# =============================================================================

# --- Claude Code CLI -----------------------------------------------------------
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-REPLACE-ME

# --- OpenAI-compatible backend -------------------------------------------------
# Point this at the official API or any OpenAI-compatible proxy you control.
# Note: GPT-5 / codex 5.x-style models use the /v1/responses endpoint, NOT the
# legacy /v1/chat/completions. Pipeline configs referencing codex 5.x should set
# `wire_api: responses`.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=REPLACE-ME

# --- Magnus cloud (optional) ---------------------------------------------------
# MAGNUS_ADDRESS=
# MAGNUS_TOKEN=
